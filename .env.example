# Tracklistify configuration example.
# Copy to .env and edit. Every variable below maps directly to a field on
# TrackIdentificationConfig (src/tracklistify/config/base.py); fields not
# declared there are NOT picked up. Regenerate with:
#     python scripts/generate_env_example.py

# --- Directories -------------------------------------------------
TRACKLISTIFY_OUTPUT_DIR=.tracklistify/output
TRACKLISTIFY_CACHE_DIR=.tracklistify/cache
TRACKLISTIFY_TEMP_DIR=.tracklistify/temp
TRACKLISTIFY_LOG_DIR=.tracklistify/log

# --- Logging -----------------------------------------------------
TRACKLISTIFY_VERBOSE=false
TRACKLISTIFY_DEBUG=false

# --- Segmentation / identification -------------------------------
TRACKLISTIFY_SEGMENT_LENGTH=60            # 10..300 seconds
TRACKLISTIFY_MIN_CONFIDENCE=0.5           # 0.0..1.0
TRACKLISTIFY_TIME_THRESHOLD=30.0          # 0.0..300.0 seconds, dedup window
TRACKLISTIFY_MAX_DUPLICATES=2             # 0..10
TRACKLISTIFY_OVERLAP_DURATION=10          # 0..30 seconds
TRACKLISTIFY_OVERLAP_STRATEGY=weighted    # weighted | longest
TRACKLISTIFY_MIN_SEGMENT_LENGTH=10        # minimum segment duration in seconds

# --- Providers ---------------------------------------------------
TRACKLISTIFY_PRIMARY_PROVIDER=shazam
TRACKLISTIFY_FALLBACK_ENABLED=false
# TRACKLISTIFY_FALLBACK_PROVIDERS=

# --- Rate limiting -----------------------------------------------
TRACKLISTIFY_RATE_LIMIT_ENABLED=true
TRACKLISTIFY_MAX_REQUESTS_PER_MINUTE=25
TRACKLISTIFY_MAX_CONCURRENT_REQUESTS=2

# --- Circuit breaker ---------------------------------------------
TRACKLISTIFY_CIRCUIT_BREAKER_ENABLED=true
TRACKLISTIFY_CIRCUIT_BREAKER_THRESHOLD=5  # consecutive failures
TRACKLISTIFY_CIRCUIT_BREAKER_RESET_TIMEOUT=60.0 # seconds

# --- Per-provider rate limits ------------------------------------
TRACKLISTIFY_SHAZAM_MAX_RPM=25
TRACKLISTIFY_SHAZAM_MAX_CONCURRENT=1
TRACKLISTIFY_SHAZAM_COOLDOWN_SECONDS=2.25
TRACKLISTIFY_ACRCLOUD_MAX_RPM=300
TRACKLISTIFY_ACRCLOUD_MAX_CONCURRENT=10
TRACKLISTIFY_SPOTIFY_MAX_RPM=120
TRACKLISTIFY_SPOTIFY_MAX_CONCURRENT=20

# --- Caching -----------------------------------------------------
TRACKLISTIFY_CACHE_ENABLED=true
TRACKLISTIFY_CACHE_TTL=3600               # seconds
TRACKLISTIFY_CACHE_MAX_SIZE=1000000       # bytes (~1MB default)
TRACKLISTIFY_CACHE_STORAGE_FORMAT=json
TRACKLISTIFY_CACHE_COMPRESSION_ENABLED=true
TRACKLISTIFY_CACHE_COMPRESSION_LEVEL=6    # 1..9
TRACKLISTIFY_CACHE_CLEANUP_ENABLED=true
TRACKLISTIFY_CACHE_CLEANUP_INTERVAL=3600  # seconds
TRACKLISTIFY_CACHE_MAX_AGE=86400          # seconds
TRACKLISTIFY_CACHE_MIN_FREE_SPACE=104857600 # bytes

# --- Output / download -------------------------------------------
TRACKLISTIFY_OUTPUT_FORMAT=json           # json | markdown | m3u
TRACKLISTIFY_DOWNLOAD_QUALITY=192         # kbps
TRACKLISTIFY_DOWNLOAD_FORMAT=mp3          # mp3 | flac | ...
TRACKLISTIFY_DOWNLOAD_MAX_RETRIES=3

# --- API credentials (do NOT commit real values) ------------------------
# These are read directly by provider modules via os.getenv, not via the
# dataclass. They are listed here for completeness.
# TRACKLISTIFY_ACR_ACCESS_KEY=
# TRACKLISTIFY_ACR_ACCESS_SECRET=
# TRACKLISTIFY_SPOTIFY_CLIENT_ID=
# TRACKLISTIFY_SPOTIFY_CLIENT_SECRET=
# TRACKLISTIFY_SPOTIFY_COOKIES=~/.mozilla/firefox/profile/cookies.sqlite
# TRACKLISTIFY_SPOTIFY_QUALITY=AAC_256
# TRACKLISTIFY_SPOTIFY_FORMAT=m4a
